# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/berkeley_safety

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001
ADMIN_TOKEN=change-me-in-production

# ── Data pipeline ─────────────────────────────────────────────────────────────
# Search provider: GDELT | GOOGLE_CSE | SERPAPI
SEARCH_PROVIDER=GDELT

# Google Programmable Search Engine (only needed if SEARCH_PROVIDER=GOOGLE_CSE)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# SerpAPI (only needed if SEARCH_PROVIDER=SERPAPI)
SERPAPI_KEY=

# Berkeley Open Data (Socrata) — dataset IDs
# Land Boundary: https://data.cityofberkeley.info/dataset/City-Boundary/9xxq-2ngu
BERKELEY_BOUNDARY_DATASET_ID=9xxq-2ngu
# Calls for Service: https://data.cityofberkeley.info/Public-Safety/Calls-for-Service-2023-2024/k2nh-s5h5
BERKELEY_CFS_DATASET_ID=k2nh-s5h5

# AC Transit GTFS static feed ZIP URL
ACTRANSIT_GTFS_URL=https://www.actransit.org/wp-content/uploads/feed.zip

# Incident search radius in meters (default 50)
INCIDENT_RADIUS_METERS=50

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
